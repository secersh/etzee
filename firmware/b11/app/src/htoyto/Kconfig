# htoyto UART protocol - configuration options

menuconfig HTOYTO_ENABLED
    bool "Enable htoyto protocol"
    default y
    select UART_ASYNC_API
    help
      Enables the etzee htoyto protocol for UART-based inter-module communication.

if HTOYTO_ENABLED

config HTOYTO_DEBOUNCE_MS
    int "dR line debounce delay in milliseconds"
    default 20
    help
      How long to wait after a dR GPIO edge before sampling the pin state.
      Filters mechanical bounce on the pogo pin connection.

config HTOYTO_UART_RX_TIMEOUT_MS
    int "UART RX idle timeout in milliseconds"
    default 5
    help
      How long after the last received byte before flushing the async DMA
      buffer. Must be short enough that multiple handshake round-trips fit
      within HTOYTO_HANDSHAKE_TIMEOUT_MS. At 115200 baud a full frame takes
      ~2 ms, so 5 ms gives ample margin without adding perceivable latency.

config HTOYTO_HANDSHAKE_TIMEOUT_MS
    int "Handshake timeout in milliseconds"
    default 200
    help
      Timeout between HLO, IAM, and EST frames before considering handshake failed.

config HTOYTO_MAX_NODE_ID_LENGTH
    int "Maximum length of node ID string"
    default 16
    help
      Maximum number of characters used to identify each htoyto node.

endif # HTOYTO_ENABLED
